# Server
PORT=3000
NODE_ENV=development

# External Alert API — The API that handles raising alarms
ALERT_ENDPOINT=http://localhost:4000/api/alerts
ALERT_API_KEY=your-api-key-here

# Alert delivery channel: api | socket | both | none
ALERT_CHANNEL=socket

# Detection Thresholds
MOTION_THRESHOLD=1
CONFIDENCE_THRESHOLD=0.6
FIRE_CONFIDENCE_THRESHOLD=0.5

# Fire Detection Mode
#   normal → realistic detection for production
#   demo   → very sensitive, triggers from a lighter or phone fire video
# Individual FIRE_* overrides below (if uncommented) take precedence over the mode.
FIRE_MODE=demo
# FIRE_RED_THRESHOLD=0.01
# FIRE_BRIGHTNESS_THRESHOLD=0.20
# FIRE_FLICKER_SENSITIVITY=0.003
# FIRE_CONSECUTIVE_FRAMES=3

# Alert Cooldown (ms) — prevents flooding the external API
ALERT_COOLDOWN_MS=30000
GUNFIRE_COOLDOWN_MS=5000

# Suspicious Object Labels (comma-separated COCO-SSD labels)
SUSPICIOUS_LABELS=knife,scissors,baseball bat

# Zone-based Intrusion Detection
ENABLE_ZONE_DETECTION=false

# Camera Identifier
CAMERA_ID=cam-01
FEED_OUTPUT_ENABLED=true
FEED_OUTPUT_DIR=./captures
# What to capture on each alert: off | image | video | both
FEED_MODE=video

# Video capture duration in seconds when alert is triggered
VIDEO_DURATION_SEC=10

# Video output format: webm (browser native) or mp4 (requires ffmpeg)
VIDEO_FORMAT=mp4

# Path to ffmpeg executable for MP4 conversion
FFMPEG_PATH=ffmpeg

# External TCP Alert Listener (send-alert / send-text on each alert)
TCP_ALERT_ENABLED=true
TCP_ALERT_HOST=127.0.0.1
TCP_ALERT_PORT=5555

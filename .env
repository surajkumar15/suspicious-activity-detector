# Server
PORT=3000
NODE_ENV=development

# External Alert API — The API that handles raising alarms
ALERT_ENDPOINT=http://localhost:4000/api/alerts
ALERT_API_KEY=your-api-key-here

# Detection Thresholds
MOTION_THRESHOLD=1
CONFIDENCE_THRESHOLD=0.6
FIRE_CONFIDENCE_THRESHOLD=0.5

# Alert Cooldown (ms) — prevents flooding the external API
ALERT_COOLDOWN_MS=30000
GUNFIRE_COOLDOWN_MS=5000

# Suspicious Object Labels (comma-separated COCO-SSD labels)
SUSPICIOUS_LABELS=knife,scissors,baseball bat

# Zone-based Intrusion Detection
ENABLE_ZONE_DETECTION=true

# Camera Identifier
CAMERA_ID=cam-01
